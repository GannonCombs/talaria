# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# Google Maps Platform API key.
# Get one at: https://console.cloud.google.com/apis/credentials
# Required APIs to enable: Street View Static API, Places API (New).
# Recommended restrictions: HTTP referrer = none, IP = 127.0.0.1 only.
GOOGLE_MAPS_API_KEY=AIza_REPLACE_ME

# Random secret used by mppx to bind challenge IDs to their content.
# Generated automatically by `npm run create-wallet` — paste the value it
# prints here. Any 32+ byte hex string is fine if you generate it manually.
MPP_SECRET_KEY=REPLACE_ME_WITH_RANDOM_HEX

# Server listen port. Default 8787.
RESELLER_PORT=8787

# Where NDJSON request logs are written. Default ./logs.
LOG_DIR=./logs
